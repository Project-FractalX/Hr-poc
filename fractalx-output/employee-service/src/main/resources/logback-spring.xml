<?xml version="1.0" encoding="UTF-8"?>
<!--
  Auto-generated by FractalX — Correlation ID logging configuration.
  Every log line includes [%X{correlationId}] so you can grep a single
  ID across all service logs to reconstruct the full request path.
  Service: employee-service
-->
<configuration>

    <!-- Console appender with correlationId in every log line -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{correlationId:-NO_CORR}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Rolling file appender — keeps 30 days of logs -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/employee-service.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/employee-service-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{correlationId:-NO_CORR}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Framework internals at INFO level -->
    <logger name="org.fractalx" level="INFO"/>
    <logger name="org.springframework" level="WARN"/>
    <logger name="io.grpc" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
