<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!--
              %X{correlationId} — injected by FractalX TraceFilter.
              Required for distributed tracing across services after decomposition.
            -->
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level [%X{correlationId}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <logger name="com.example.hr" level="DEBUG"/>
    <logger name="org.fractalx"   level="INFO"/>
</configuration>
